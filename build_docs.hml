    ru["Project Setup"] = "Настройка проекта"; ru["Troubleshooting"] = "Устранение неполадок";
    ru["Creating Packages"] = "Создание пакетов"; ru["Package Spec"] = "Спецификация пакетов";
    ru["Versioning"] = "Версионирование"; ru["Architecture"] = "Архитектура";
    ru["Exit Codes"] = "Коды выхода";
    t.ru = ru;

    return t;
}
