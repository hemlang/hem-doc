// Build the Hemlock documentation viewer.
//
// This script generates a standalone HTML file (docs.html) that includes:
// - All markdown documentation from the hemlock submodule
// - Embedded content (no HTTP server required)
// - Beautiful sage/pine green theme
// - Multi-page navigation
// - Multi-language support
// - Dark mode toggle
// - Search functionality
// - LLM-friendly plain text output
//
// Usage:
//     hemlock build_docs.hml           # Build English docs (default)
//     hemlock build_docs.hml --lang zh # Build Chinese docs
//     hemlock build_docs.hml --lang all # Build all available languages
//
// The hemlock submodule must be initialized before running this script:
//     git submodule update --init --recursive

import { read_file, write_file, exists, list_dir, is_file, is_dir } from "@stdlib/fs";
import { base64_encode } from "@stdlib/encoding";
import { stringify } from "@stdlib/json";
import { args } from "@stdlib/env";

// Paths to submodules and translations
let HEMLOCK_DIR = "hemlock";
let HPM_DIR = "hpm";
let TRANSLATIONS_DIR = "translations";
let WELCOME_DIR = "welcome";

// Supported languages with display names
let SUPPORTED_LANGUAGES = {
    en: "English",
    zh: "中文",
    de: "Deutsch",
    es: "Español",
    fr: "Français",
    it: "Italiano",
    ja: "日本語",
    pt: "Português",
    ru: "Русский"
};

